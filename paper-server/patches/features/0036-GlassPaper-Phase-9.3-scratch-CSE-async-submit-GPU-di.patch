             NoiseChunk.NoiseInterpolator interp = this.interpolators.get(i);
             io.papermc.paper.gpu.GpuCompiledKernel ck = compiledKernels[i];
 
             if (ck != null && gpuKernel != null) {
-                io.papermc.paper.gpu.GpuDispatchQueue queue =
-                    io.papermc.paper.gpu.GpuKernelHolder.getDispatchQueue();
-
                 double[] results;
                 if (queue != null) {
-                    results = queue.submit(positions, ck, pointsPerInterp);
+                    results = queue.awaitResult(pending[i]);
                 } else {
                     long gpuStart = System.nanoTime();
                     results = gpuKernel.evalDensityTreeFast(positions, ck, pointsPerInterp);
@@ -341,7 +358,6 @@ public class NoiseChunk implements DensityFunction.ContextProvider, DensityFunct
                         System.nanoTime() - gpuStart, pointsPerInterp);
                 }
 
-
                 if (results != null) {
                     for (int zi = 0; zi < zColumns; zi++) {
                         double[] slice = (isSlice0 ? interp.slice0 : interp.slice1)[zi];
