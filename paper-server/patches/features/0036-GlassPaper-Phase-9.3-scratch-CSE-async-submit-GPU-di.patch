diff --git a/net/minecraft/server/dedicated/DedicatedServer.java b/net/minecraft/server/dedicated/DedicatedServer.java
index 6db614169ddf887a885e4df14a3193851b713662..fa6530afb9b1a1132cbab529da1c0623f5433fc6 100644
--- a/net/minecraft/server/dedicated/DedicatedServer.java
+++ b/net/minecraft/server/dedicated/DedicatedServer.java
@@ -619,6 +619,18 @@ public class DedicatedServer extends MinecraftServer implements ServerInterface
             return;
         }
 
+        if (msg.equalsIgnoreCase("gpudisable") || msg.equalsIgnoreCase("gpuenable")) {
+            boolean disable = msg.equalsIgnoreCase("gpudisable");
+            io.papermc.paper.gpu.GpuKernelHolder.setDisabled(disable);
+            if (disable) {
+                LOGGER.info("GPU acceleration DISABLED. All density functions now run on CPU.");
